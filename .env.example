# ============================================
# Next.js Frontend Environment Variables (Vercel)
# ============================================

# [Client-side] - 브라우저 노출 가능
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=GyoanMaker

# [Server-side] - Vercel 서버리스 함수 전용 (브라우저 노출 안됨)
# Cloud Run 백엔드 보호를 위한 프록시 설정
CLOUDRUN_API_BASE_URL=http://localhost:4000
CLOUDRUN_API_KEY=your-secure-api-key-here

# ============================================
# Backend API (server.js) Environment Variables
# Cloud Run 배포용
# ============================================

# 인증 및 보안 (필수)
API_KEY=your-secure-api-key-here
ADMIN_KEY=your-secure-admin-key-here

# Vertex AI
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=asia-northeast3

# API Key (로컬 테스트 전용)
# GOOGLE_CLOUD_API_KEY=
# GOOGLE_API_KEY=

# 시스템 프롬프트
# 우선순위: SYSTEM_PROMPT_B64 > SYSTEM_PROMPT > server/system-prompt.txt (기본값)
SYSTEM_PROMPT_B64=
SYSTEM_PROMPT=

# 서버 설정
PORT=4000
PROCESSING_MODE=sequential
# PARALLEL_LIMIT=3
