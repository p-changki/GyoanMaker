# ============================================
# Next.js Frontend Environment Variables
# 이 파일을 .env.local로 복사해 실제 값을 입력하세요
# ⚠️ .env.local 파일은 Git에 커밋하지 마세요
# ============================================

# 공개 환경 변수 (브라우저 노출)
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=local
NEXT_PUBLIC_APP_NAME=GyoanMaker
NEXT_PUBLIC_ENABLE_MOCK_API=false
NEXT_PUBLIC_INITIAL_GENERATE_CHUNK_SIZE=1
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_ck_xxxxxxxxxx
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# 결제 (Toss Payments)
TOSS_SECRET_KEY=test_sk_xxxxxxxxxx

# Sentry (release / source map 업로드용, 서버 전용)
SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENTRY_ORG=your-sentry-org-slug
SENTRY_PROJECT=your-sentry-project-slug

# [Server-side] - 브라우저 노출 금지 (Vercel Proxy용)
CLOUDRUN_API_BASE_URL=http://127.0.0.1:4000
CLOUDRUN_API_KEY=your-secure-api-key-here
CLOUDRUN_API_TIMEOUT_MS=55000
PROXY_RATE_LIMIT_WINDOW_MS=60000
PROXY_RATE_LIMIT_MAX=20

# 삽화 생성 (Next.js server-side)
GOOGLE_IMAGE_API_KEY=your-google-image-api-key-here
ILLUSTRATION_MODEL_DEFAULT=gemini-3.1-flash-image-preview
ILLUSTRATION_MODEL_HQ=gemini-3-pro-image-preview
ILLUSTRATION_ALLOW_PLACEHOLDER=false
# signed URL 만료(초) - 기본 30일, 최대 365일
ILLUSTRATION_SIGNED_URL_TTL_SECONDS=2592000


# ============================================
# Backend API (server.js) Environment Variables
# Cloud Run 배포 시 환경변수로 설정 (Git에 커밋 금지)
# ============================================

# Vertex AI (운영 — Cloud Run ADC 인증)
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=asia-northeast3

# API Key (로컬 테스트 전용 — 운영 사용 금지)
# 우선순위: GOOGLE_CLOUD_API_KEY > GOOGLE_API_KEY (하위호환)
# GOOGLE_CLOUD_API_KEY=
GOOGLE_API_KEY=your-google-api-key-here

# 시스템 프롬프트 (필수)
# 우선순위: SYSTEM_PROMPT_B64 > SYSTEM_PROMPT > server/system-prompt.txt
# Cloud Run에서는 줄바꿈이 깨질 수 있으므로 B64 사용 권장
# 생성: cat server/system-prompt.txt | base64 -w0
SYSTEM_PROMPT_B64=
SYSTEM_PROMPT=

# 서버 설정
PORT=4000
PROCESSING_MODE=parallel
PARALLEL_LIMIT=3
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
GENERATE_RATE_LIMIT_WINDOW_MS=60000
GENERATE_RATE_LIMIT_MAX=20
META_RATE_LIMIT_WINDOW_MS=60000
META_RATE_LIMIT_MAX=5

# 백엔드 인증 키 (Proxy의 CLOUDRUN_API_KEY와 일치해야 함)
API_KEY=your-secure-api-key-here
ADMIN_KEY=your-secure-admin-key-here

# 키 롤링 시 다중 키 사용 (쉼표 구분, 선택)
# API_KEYS=next-api-key,previous-api-key
# ADMIN_KEYS=next-admin-key,previous-admin-key


# ============================================
# Google OAuth (NextAuth.js) - 인증/인가
# Google Cloud Console → APIs & Services → Credentials에서 발급
# ============================================

NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-random-secret-here

# Google OAuth 2.0 Client Credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# 관리자 이메일 (쉼표 구분) - /admin 페이지 접근 권한
ADMIN_EMAILS=your-admin-email@gmail.com

# ============================================
# Firebase Admin (Firestore 사용자 DB)
# Google Cloud → IAM → Service Accounts에서 생성
# ============================================
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
