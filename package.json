{
  "name": "gyoanmaker",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.17.1",
  "workspaces": ["apps/*", "packages/*"],
  "engines": {
    "node": ">=20.9"
  },
  "scripts": {
    "dev": "turbo dev --parallel",
    "dev:web": "turbo dev --filter=@gyoanmaker/web",
    "dev:api": "turbo dev --filter=@gyoanmaker/api",
    "build": "turbo build",
    "type-check": "turbo type-check",
    "lint": "turbo lint",
    "lint:fix": "turbo lint -- --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "prettier": "^3.0.0",
    "turbo": "^2.5.6",
    "typescript": "^5"
  }
}
